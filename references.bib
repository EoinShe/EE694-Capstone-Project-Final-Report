  pages     = {1--2},
  file      = {Full Text PDF:C\:\\Users\\Eoin\\Zotero\\storage\\68EPBCRW\\Nagy et al. - 2018 - Low-reaction time FPGA-based DDoS detector.pdf:application/pdf}
