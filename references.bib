  month      = feb,
  year       = {2009},
  keywords   = {Anomaly detection, Assessment, IDS systems and platforms, Intrusion detection, Network security, Threat},
  pages      = {18--28},
  file       = {ScienceDirect Snapshot:C\:\\Users\\Eoin\\Zotero\\storage\\TN884ICC\\S0167404808000692.html:text/html}
