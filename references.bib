@article{abiramasundari_distributed_2025,
  title     = {Distributed denial-of-service ({DDOS}) attack detection using supervised machine learning algorithms},
  volume    = {15},
  copyright = {2025 The Author(s)},
  issn      = {2045-2322},
  url       = {https://www.nature.com/articles/s41598-024-84879-y},
  doi       = {10.1038/s41598-024-84879-y},
  abstract  = {Distributed Denial-of-Service (DDoS) attacks have become a critical issue in cyber security. This can lead to a temporary or even prolonged loss of service for users. These attacks mainly target e-commerce platforms, online services, and financial institutions. DDoS attacks need to be detected since they cause serious problems. Supervised machine learning models are effective mechanisms for detecting DDoS attacks. In this paper, a PCA-based Enhanced Distributed DDoS Attack Detection (EDAD) framework has been proposed. Various Machine Learning (ML) algorithms and feature selection techniques have been used to detect DDoS attacks. Support Vector Machine (SVM), Logistic Regression (LR), Random Forest (RF), K-Nearest Neighbours (KNN), Decision Tree (DT) supervised models, and Principle Component Analysis (PCA) feature selection method are used to differentiate between attack and regular traffic. The CICIDS2018, CICIDS2017, and CICDDoS-2019 datasets are used to evaluate the performances of ML algorithms. Various performance metrics of these algorithms are studied and compared to find the best algorithm that yields the highest accuracy. It is found that RF yields the highest accuracy of 98.9\% on CICIDS2017. In the CICDDoS2019 dataset, RF and KNN yield a higher accuracy of 98.7. On the CICIDS2018 dataset, SVM gives the highest accuracy of 98.7\%.},
  language  = {en},
  number    = {1},
  urldate   = {2025-12-22},
  journal   = {Scientific Reports},
  publisher = {Nature Publishing Group},
  author    = {Abiramasundari, S. and Ramaswamy, V.},
  month     = apr,
  year      = {2025},
  keywords  = {Engineering, Mathematics and computing},
  pages     = {13098},
  file      = {Full Text PDF:C\:\\Users\\Eoin\\Zotero\\storage\\9XD57H6B\\Abiramasundari and Ramaswamy - 2025 - Distributed denial-of-service (DDOS) attack detection using supervised machine learning algorithms.pdf:application/pdf}
}

@article{su_comprehensive_2024,
