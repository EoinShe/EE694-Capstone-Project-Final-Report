  keywords = {Extended Kalman filter, Fluid flow measurement, freeway networks, Length measurement, on-line model parameter estimation, Predictive models, queue tracking, State estimation, stochastic macroscopic freeway network traffic flow model, Stochastic processes, Surveillance, Telecommunication traffic, Testing, Time measurement, Traffic control, traffic state estimation and prediction, traffic surveillance, travel time estimation and prediction},
